{
  "name": "runeoftheday",
  "main": "index.ts",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "expo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "build:android": "eas build -p android",
    "build:android:preview": "eas build -p android --profile preview",
    "build:ios": "eas build -p ios",
    "build:ios:preview": "eas build -p ios --profile preview",
    "submit:android": "eas submit -p android",
    "submit:ios": "eas submit -p ios",
    "prepare": "husky"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "collectCoverageFrom": [
      "app/**/*.{ts,tsx}",
      "!app/**/*.d.ts",
      "!app/**/__tests__/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 65,
        "functions": 60,
        "lines": 65,
        "statements": 65
      }
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "^56.0.0",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.19",
    "expo-constants": "~56.0.18",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.14",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "prettier": "^3.5.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-android-widget": "^0.20.3",
    "react-native-flip-card": "^3.5.7",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.17",
    "@types/react-native-flip-card": "^3.5.7",
    "@types/react-test-renderer": "~19.1.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "husky": "^9.1.7",
    "jest": "^29.2.1",
    "jest-expo": "~56.0.5",
    "lint-staged": "^17.0.8",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,html,css}": [
      "prettier --write"
    ]
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": []
      }
    }
  }
}
